<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:ARWtoJXL.Avalonia"
        xmlns:vm="using:ARWtoJXL.Avalonia.ViewModels"
        xmlns:core="using:ARWtoJXL.Core.Interfaces"
        xmlns:conv="using:ARWtoJXL.Avalonia.Converters"
        x:Class="ARWtoJXL.Avalonia.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="480" Height="680"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Window.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,10">
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Quality:" VerticalAlignment="Center" FontSize="12"/>
                    <StackPanel Grid.Column="1" Orientation="Vertical">
                        <TextBlock Text="{Binding QualityPreset}" HorizontalAlignment="Right" FontSize="11" Foreground="Gray"/>
                        <Slider Minimum="0" Maximum="100" Value="{Binding QualityPreset}" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,2"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Output format:" VerticalAlignment="Center" FontSize="12"/>
                    <ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                              SelectedValue="{Binding OutputFormat}"
                              SelectedValueBinding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ComboBoxItem}}">
                        <ComboBoxItem Content="JPEG XL (.jxl)" Tag="{x:Static core:OutputFormat.Jxl}"/>
                        <ComboBoxItem Content="JPEG (.jpg)" Tag="{x:Static core:OutputFormat.Jpeg}"/>
                        <ComboBoxItem Content="PNG (.png)" Tag="{x:Static core:OutputFormat.Png}"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Use subfolder:" VerticalAlignment="Center" FontSize="12"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding UseSubfolder}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Subfolder name:" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox Grid.Column="1" Text="{Binding SubfolderName}" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="{Binding SubfolderNameValidationResult}"
                           Foreground="Red" FontSize="11" Margin="142,2,0,0"
                           IsVisible="{Binding SubfolderNameValidationResult, Converter={StaticResource StringToVisibilityConverter}}"/>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Custom output dir:" VerticalAlignment="Center" FontSize="12"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding UseCustomOutputDirectory}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,4" IsVisible="{Binding UseCustomOutputDirectory}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="1" Text="{Binding CustomOutputDirectory}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Browse" Command="{Binding BrowseOutputDirectoryCommand}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Recursive folder:" VerticalAlignment="Center" FontSize="12"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding SearchRecursive}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="File conflict:" VerticalAlignment="Center" FontSize="12"/>
                    <ComboBox Grid.Column="1" Width="180" HorizontalAlignment="Left"
                              SelectedValue="{Binding ConflictResolution}"
                              SelectedValueBinding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ComboBoxItem}}">
                        <ComboBoxItem Content="Overwrite existing" Tag="{x:Static local:ConflictResolution.Overwrite}"/>
                        <ComboBoxItem Content="Skip existing" Tag="{x:Static local:ConflictResolution.Skip}"/>
                        <ComboBoxItem Content="Append number" Tag="{x:Static local:ConflictResolution.AppendNumber}"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Confirm overwrite:" VerticalAlignment="Center" FontSize="12"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding ConfirmOverwrite}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Skip metadata:" VerticalAlignment="Center" FontSize="12"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding SkipMetadata}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="cjxl effort:" VerticalAlignment="Center" FontSize="12"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ComboBox Width="60" HorizontalAlignment="Left" Margin="0,0,8,0"
                                  SelectedItem="{Binding CjxlEffort}"
                                  VerticalAlignment="Center">
                            <ComboBoxItem Content="Auto" Tag="-1"/>
                            <ComboBoxItem Content="1" Tag="1"/>
                            <ComboBoxItem Content="2" Tag="2"/>
                            <ComboBoxItem Content="3" Tag="3"/>
                            <ComboBoxItem Content="4" Tag="4"/>
                            <ComboBoxItem Content="5" Tag="5"/>
                            <ComboBoxItem Content="6" Tag="6"/>
                            <ComboBoxItem Content="7" Tag="7"/>
                            <ComboBoxItem Content="8" Tag="8"/>
                            <ComboBoxItem Content="9" Tag="9"/>
                        </ComboBox>
                        <TextBlock Text="(1=fastest, 9=best)" FontSize="10" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="cjxl raw distance:" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox Grid.Column="1" Text="{Binding CjxlRawDistance}" Width="80" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="{Binding CjxlRawDistanceValidationResult}"
                           Foreground="Red" FontSize="11" Margin="142,2,0,0"
                           IsVisible="{Binding CjxlRawDistanceValidationResult, Converter={StaticResource StringToVisibilityConverter}}"/>

                <Separator Margin="0,12,0,8"/>
                <TextBlock Text="Presets" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Presets}"
                              SelectedItem="{Binding SelectedPreset}"
                              Width="200" HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="1" Content="Load" Command="{Binding LoadPresetCommand}"
                            Margin="4,0,0,0" IsEnabled="{Binding HasSelectedPreset}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewPresetName}"
                             ToolTip.Tip="Preset name" Width="140" HorizontalAlignment="Left" Margin="0,0,4,0"/>
                    <Button Grid.Column="1" Content="Save As" Command="{Binding AddPresetCommand}"/>
                    <Button Grid.Column="2" Content="Delete" Command="{Binding RemovePresetCommand}"
                            IsEnabled="{Binding HasSelectedPreset}"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Save" Command="{Binding SaveCommand}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
