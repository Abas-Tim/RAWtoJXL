<Window x:Class="ARWtoJXL.WPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ARWtoJXL.WPF"
        xmlns:vm="clr-namespace:ARWtoJXL.WPF.ViewModels"
        xmlns:core="clr-namespace:ARWtoJXL.Core.Interfaces;assembly=ARWtoJXL.Core"
        Title="Settings"
        Height="380" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,10">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Use subfolder:"/>
                <CheckBox Grid.Column="1" Content="" IsChecked="{Binding UseSubfolder}"/>
            </Grid>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Subfolder name:"/>
                <TextBox Grid.Column="1" Text="{Binding SubfolderName}"/>
            </Grid>
            <TextBlock Text="{Binding SubfolderNameValidationResult}"
                       Foreground="Red" FontSize="11" Margin="142,2,0,0"
                       Visibility="{Binding SubfolderNameValidationResult, Converter={StaticResource StringToVisibilityConverter}}"/>

            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Quality:"/>
                <StackPanel Grid.Column="1" Orientation="Vertical">
                    <TextBlock Text="{Binding QualityPreset}" HorizontalAlignment="Right" FontSize="11" Foreground="Gray"/>
                    <Slider Minimum="0" Maximum="100" Value="{Binding QualityPreset}" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,2"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Recursive folder:"/>
                <CheckBox Grid.Column="1" Content="" IsChecked="{Binding SearchRecursive}"/>
            </Grid>

            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Output format:"/>
                <ComboBox Grid.Column="1" Width="120" HorizontalAlignment="Left"
                          SelectedValue="{Binding OutputFormat}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="JPEG XL (.jxl)" Tag="{x:Static core:OutputFormat.Jxl}"/>
                    <ComboBoxItem Content="JPEG (.jpg)" Tag="{x:Static core:OutputFormat.Jpeg}"/>
                    <ComboBoxItem Content="PNG (.png)" Tag="{x:Static core:OutputFormat.Png}"/>
                </ComboBox>
            </Grid>

            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="File conflict:"/>
                <ComboBox Grid.Column="1" Width="180" HorizontalAlignment="Left"
                          SelectedValue="{Binding ConflictResolution}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Overwrite existing" Tag="{x:Static core:ConflictResolution.Overwrite}"/>
                    <ComboBoxItem Content="Skip existing" Tag="{x:Static core:ConflictResolution.Skip}"/>
                    <ComboBoxItem Content="Append number" Tag="{x:Static core:ConflictResolution.AppendNumber}"/>
                </ComboBox>
            </Grid>

            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Confirm overwrite:"/>
                <CheckBox Grid.Column="1" Content="" IsChecked="{Binding ConfirmOverwrite}"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Command="{Binding SaveCommand}"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
