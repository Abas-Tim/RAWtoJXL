<Window x:Class="ARWtoJXL.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ARWtoJXL.WPF.ViewModels"
        xmlns:models="clr-namespace:ARWtoJXL.WPF.Models"
        xmlns:local="clr-namespace:ARWtoJXL.WPF"
        mc:Ignorable="d"
        Title="ARW to JXL Converter" Height="700" Width="900"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:ImageStatusToStringConverter x:Key="ImageStatusToStringConverter"/>
        <local:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <local:BooleanToTextConverter x:Key="BooleanToTextConverter"/>
        <local:BooleanToValueConverter x:Key="BooleanToValueConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

      <!-- Header / Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Background="#F0F0F0">
              <Button Content="{Binding IsAllSelected, Converter={StaticResource BooleanToTextConverter}, ConverterParameter='Deselect All'}" 
                        Command="{Binding SelectAllCommand}"
                        Padding="10,5"
                        Margin="0,0,5,0"
                        AutomationProperties.AutomationId="SelectAllButton"/>
             <Button Content="Convert" 
                       Command="{Binding ConvertSelectedCommand}"
                       Padding="10,5"
                       Margin="5,0,0,0"
                       AutomationProperties.AutomationId="ConvertSelectedButton"/>
             <Button Content="Remove" 
                       Command="{Binding RemoveSelectedCommand}"
                       Padding="10,5"
                       Margin="5,0,0,0"
                       AutomationProperties.AutomationId="RemoveButton"/>
             <Button Content="Cancel" 
                       Command="{Binding CancelCommand}"
                       Padding="10,5"
                       Margin="5,0,0,0"
                       AutomationProperties.AutomationId="CancelButton"/>
             <TextBlock Text="{Binding StatusMessage}" 
                         VerticalAlignment="Center" 
                         Margin="20,0"
                         FontSize="12"
                         Foreground="Gray"/>
         </StackPanel>

        <!-- Settings Panel -->
        <Expander Grid.Row="1" Header="Settings" IsExpanded="False" Margin="10">
            <StackPanel Margin="10">
                <CheckBox Content="Use subfolder for output" IsChecked="{Binding UseSubfolder}" Margin="0,0,0,10"/>
                
                <TextBlock Text="Subfolder name:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding SubfolderName}" Margin="0,0,0,10" Width="300"/>
                
                <TextBlock Text="Output format:" Margin="0,10,0,5"/>
                <ComboBox ItemsSource="{Binding OutputFormats}" SelectedItem="{Binding OutputFormat}" Width="200" Margin="0,0,0,10"/>
                
                <TextBlock Text="Quality (0-100, higher = better quality):" Margin="0,0,0,5"/>
                <Slider Minimum="0" Maximum="100" Value="{Binding QualityPreset}" TickFrequency="1" IsSnapToTickEnabled="True" Width="300" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding QualityPreset, StringFormat='Current: {0}'}" HorizontalAlignment="Center" FontSize="11" Foreground="Gray"/>
            </StackPanel>
        </Expander>

<!-- File List -->
<ListBox Grid.Row="2" ItemsSource="{Binding Images}" Margin="10" SelectionMode="Extended">
    <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>
    </ListBox.ItemContainerStyle>
    <ListBox.ItemTemplate>
        <DataTemplate DataType="{x:Type models:ImageItem}">
            <StackPanel Orientation="Horizontal" Margin="5,2">
                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,10,0"/>
                <Image Source="{Binding Thumbnail}" Width="80" Height="60" Stretch="Uniform" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="{Binding FileName}" FontSize="13"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <ProgressBar Width="150" Height="4" IsIndeterminate="True" Visibility="{Binding Status, Converter={StaticResource ImageStatusToStringConverter}, ConverterParameter='Converting'}"/>
                        <TextBlock Text="{Binding Status, StringFormat='Status: {0}'}" FontSize="11" Foreground="Gray" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="11" Foreground="Red" Visibility="{Binding ErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </ListBox.ItemTemplate>
</ListBox>

       <!-- Footer / Status -->
        <StackPanel Grid.Row="3" Margin="10">
            <ProgressBar Minimum="0" Maximum="{Binding TotalCount, Converter={StaticResource BooleanToValueConverter}, ConverterParameter='DefaultIfZero'}" Value="{Binding CompletedCount}" 
                          Height="20" Margin="0,0,0,5"
                          Visibility="{Binding IsConverting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" FontSize="11"/>
        </StackPanel>
    </Grid>
</Window>
