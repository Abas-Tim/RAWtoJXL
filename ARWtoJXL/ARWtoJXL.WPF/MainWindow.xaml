<Window x:Class="ARWtoJXL.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ARWtoJXL.WPF.ViewModels"
        xmlns:models="clr-namespace:ARWtoJXL.WPF.Models"
        xmlns:local="clr-namespace:ARWtoJXL.WPF"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="ARW to JXL Converter"
        Height="750" Width="1000"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+A" Command="{Binding SelectAllCommand}"/>
        <KeyBinding Gesture="Ctrl+C" Command="{Binding ConvertSelectedCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding RemoveSelectedCommand}"/>
        <KeyBinding Gesture="Ctrl+D" Command="{Binding OpenFileCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:ImageStatusToStringConverter x:Key="ImageStatusToStringConverter"/>
        <local:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <local:BooleanToTextConverter x:Key="BooleanToTextConverter"/>
        <local:BooleanToValueConverter x:Key="BooleanToValueConverter"/>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Wpf.Ui.Brush.Control.Default}"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>

        <DataTemplate DataType="{x:Type models:ImageItem}">
            <Border Background="{DynamicResource Wpf.Ui.Brush.Background.Brush}"
                    BorderBrush="{DynamicResource Wpf.Ui.Brush.Control.Default}"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,3"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsSelected}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>

                    <Image Grid.Column="1"
                           Source="{Binding Thumbnail}"
                           Width="80"
                           Height="60"
                           Stretch="Uniform"
                           Margin="0,0,15,0"
                           VerticalAlignment="Top"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                      <TextBlock Text="{Binding FileName}"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ProgressBar Width="160"
                                         Height="4"
                                         IsIndeterminate="True"
                                         Visibility="{Binding Status, Converter={StaticResource ImageStatusToStringConverter}, ConverterParameter='Converting'}"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Status, StringFormat='Status: {0}'}"
                                       FontSize="11"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="11"
                                   Foreground="Red"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header / Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Wpf.Ui.Brush.Background.Brush}"
                BorderBrush="{DynamicResource Wpf.Ui.Brush.Control.Default}"
                BorderThickness="0,0,0,1"
                Padding="15,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:Button Content="Open File"
                               Command="{Binding OpenFileCommand}"
                               Margin="0,0,8,0"
                               Icon="DocumentAdd16"/>
                    <ui:Button Content="Select All"
                               Command="{Binding SelectAllCommand}"
                               Margin="0,0,8,0"/>
                    <ui:Button Content="Convert"
                               Command="{Binding ConvertSelectedCommand}"
                               Margin="0,0,8,0"
                               Appearance="Primary"/>
                    <ui:Button Content="Remove"
                               Command="{Binding RemoveSelectedCommand}"
                               Margin="0,0,8,0"/>
                    <ui:Button Content="Cancel"
                               Command="{Binding CancelCommand}"
                               Appearance="Danger"
                               Visibility="{Binding IsConverting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <ui:Button Content="Open Output Folder"
                               Command="{Binding OpenOutputFolderCommand}"
                               Icon="Folder24"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Content="Settings"
                               Click="SettingsButton_Click"
                               Margin="0,0,12,0"
                               Icon="Settings24"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- File List -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Images}"
                 Margin="15"
                 SelectionMode="Extended"
                 BorderThickness="1">
        </ListBox>

        <!-- Footer / Progress -->
        <Border Grid.Row="2"
                Background="{DynamicResource Wpf.Ui.Brush.Background.Brush}"
                BorderBrush="{DynamicResource Wpf.Ui.Brush.Control.Default}"
                BorderThickness="0,1,0,0"
                Padding="15,10">
            <StackPanel>
                <ProgressBar Minimum="0"
                             Maximum="{Binding TotalCount, Converter={StaticResource BooleanToValueConverter}, ConverterParameter='DefaultIfZero'}"
                             Value="{Binding CompletedCount}"
                             Height="5"
                             Margin="0,0,0,8"
                             Visibility="{Binding IsConverting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBlock Text="{Binding StatusMessage}"
                           HorizontalAlignment="Center"
                           FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
