<Window x:Class="ARWtoJXL.WPF.Services.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TitleText, RelativeSource={RelativeSource AncestorType=Window}}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="{Binding MessageText, RelativeSource={RelativeSource AncestorType=Window}}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Yes" Width="80" Margin="0,0,8,0" Click="YesButton_Click" IsDefault="True"/>
            <Button Content="No" Width="80" Click="NoButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
